# =============================================================================
# FUSE Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Chat Provider (Recommended for proof of concept: OpenAI mini)
# -----------------------------------------------------------------------------
# Set to "openai" to run the public FUSE Agent through the OpenAI Responses API.
# If omitted, the app uses OpenAI when OPENAI_API_KEY exists, otherwise Anthropic.
FUSE_CHAT_PROVIDER=openai
FUSE_CHAT_MODEL=gpt-5-mini

# OpenAI API Key (Required when FUSE_CHAT_PROVIDER=openai)
# -----------------------------------------------------------------------------
# Get your key at: https://platform.openai.com/api-keys
# Key must start with "sk-"
OPENAI_API_KEY=

# Research Lab AI Brain (Optional, recommended for daily discovery value)
# -----------------------------------------------------------------------------
# The lab uses deterministic simulation for browser ticks, then calls OpenAI once
# during the daily cron run to synthesize a useful discovery brief.
# Set FUSE_LAB_AI_ENABLED=false to force deterministic fallback.
FUSE_LAB_AI_ENABLED=true
FUSE_LAB_AI_MODEL=gpt-5-mini
FUSE_LAB_WEEKLY_MODEL=gpt-5.5
FUSE_LAB_WEEKLY_REASONING=high

# Vercel Cron Secret (Required in production for /api/research-lab-daily)
# -----------------------------------------------------------------------------
# Set a strong random value and configure Vercel Cron to send:
# Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Anthropic API Key (Required when FUSE_CHAT_PROVIDER=anthropic)
# -----------------------------------------------------------------------------
# Get your key at: https://console.anthropic.com/
# The key MUST start with "sk-ant-" - copy the full key from the console
# Without this key, the chat agent will return 503 errors
# Example: ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=

# Vercel Blob Storage Token (Required for waitlist signups)
# -----------------------------------------------------------------------------
# Get this from your Vercel project: Settings > Storage > Blob
BLOB_READ_WRITE_TOKEN=

# Admin Passkey Login (Required for accessing admin panel and agent management)
# -----------------------------------------------------------------------------
# Username defaults to sergiopesch. The password hash is used only to create or
# recover an admin passkey; normal admin login uses WebAuthn passkeys.
# Generate a password hash with:
#   node scripts/generate-admin-password-hash.js "your-password"
ADMIN_USERNAME=sergiopesch
ADMIN_PASSWORD_HASH=

# Signed admin session secret. Minimum 32 characters recommended:
#   openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Legacy/direct API admin token fallback. Keep for scripts and emergency access.
ADMIN_TOKEN=

# Encryption Key (Required for securing PII)
# -----------------------------------------------------------------------------
# Must be at least 32 characters long
# Used to encrypt personally identifiable information in storage
# Example: openssl rand -hex 32
ENCRYPTION_KEY=

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Alternative Agent API Token (Optional)
# -----------------------------------------------------------------------------
# If set, can be used instead of ADMIN_TOKEN for agent API authentication
# Useful for separating admin and agent API access
AGENTS_API_TOKEN=

# WebAuthn Settings (Optional)
# -----------------------------------------------------------------------------
# Override WebAuthn RP ID and allowed origins for biometric login.
# Comma-separated values are supported for multi-domain setups.
# Example: WEBAUTHN_RP_ID=fusecreatine.com,www.fusecreatine.com
# Example: WEBAUTHN_ORIGINS=https://fusecreatine.com,https://www.fusecreatine.com
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGINS=

# CEO Authentication (Simple, cost-effective dashboard access)
# -----------------------------------------------------------------------------
# CEO/Admin email for magic link authentication
CEO_EMAIL=speschiera@gmail.com

# CEO PIN (RECOMMENDED - enables instant PIN-based login, no external services)
# Set a memorable PIN for quick dashboard access
# Minimum 4 characters recommended
# Example: CEO_PIN=1234 or CEO_PIN=mySecurePin2024
CEO_PIN=

# Resend API Key (Optional - enables email-based magic links)
# Get your key at: https://resend.com/api-keys
# Without this key, magic link tokens are logged to console (dev mode only)
# NOTE: Magic links work WITHOUT Redis - they use stateless HMAC tokens
RESEND_API_KEY=

# Resend From Email (Optional)
# The email address magic links are sent from
# Must be verified in your Resend dashboard
# Default: FUSE <noreply@fusecreatine.com>
RESEND_FROM_EMAIL=

# Google Gemini API Key (Optional - for multi-provider agent support)
# -----------------------------------------------------------------------------
# Get your key at: https://makersuite.google.com/app/apikey
# Key must start with "AI"
GEMINI_API_KEY=

# =============================================================================
# REDIS STATE + RATE LIMITING (Recommended for Production)
# =============================================================================

# Upstash Redis REST URL (Optional)
# -----------------------------------------------------------------------------
# Get this from: https://console.upstash.com/
# Required for persistent admin passkeys and distributed rate limiting across
# serverless functions. Use the env names created by Vercel's Upstash
# integration when the custom prefix is UPSTASH_REDIS.
UPSTASH_REDIS_KV_REST_API_URL=

# Upstash Redis REST Token (Recommended)
# -----------------------------------------------------------------------------
# Authentication token for Upstash Redis
UPSTASH_REDIS_KV_REST_API_TOKEN=

# =============================================================================
# COST MANAGEMENT (Optional but Recommended)
# =============================================================================

# Daily Budget Limit (Optional)
# -----------------------------------------------------------------------------
# Maximum API spend per day in USD
# When exceeded, budget alerts will be generated
# Default: 50.00
DAILY_BUDGET_LIMIT=50.00

# Monthly Budget Limit (Optional)
# -----------------------------------------------------------------------------
# Maximum API spend per month in USD
# When exceeded, budget alerts will be generated
# Default: 500.00
MONTHLY_BUDGET_LIMIT=500.00

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. NEVER commit your .env file to version control
#    The .gitignore should already exclude it
#
# 2. In Vercel, set these as Environment Variables in your project settings:
#    Settings > Environment Variables
#
# 3. For production, use different tokens than development
#
# 4. Rotate your tokens periodically for security
#
# 5. API Key format validation:
#    - Anthropic: must start with "sk-ant-"
#    - OpenAI: must start with "sk-"
#    - Gemini: must start with "AI"
#
# 6. CEO Dashboard Authentication Options:
#    - PIN (CEO_PIN): Simple, instant, no external services required
#    - Magic Link (RESEND_API_KEY): Email-based, no Redis required
#    - Biometric (WebAuthn): Device-based, most secure but device-dependent
#
#    RECOMMENDED: Set CEO_PIN for quick access, add RESEND_API_KEY for backup
#
# =============================================================================
